VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Leave empty for local dev: Vite proxies /api → http://127.0.0.1:5000 (see vite.config.js).
# Or set e.g. http://127.0.0.1:5000 to call Flask directly (CORS is enabled on the API).
VITE_UBUNTU_SERVER=
# AI chat: POST {VITE_UBUNTU_SERVER or same-origin}/api/chat. OPENAI_API_KEY only on the Flask server — see server/app.py.
# Flask server (export in shell or use a server-only env file): OPENAI_API_KEY, OPENAI_MODEL (optional), BOOK1_CSV_PATH (optional path to book1.csv; default is ../src/data/book1.csv from server/).
# Optional: OPENAI_MAX_COMPLETION_TOKENS (default 96, keeps replies short), OPENAI_TEMPERATURE (default 0.2).
# Token-cost tracking: path to Firebase service-account JSON (server-side).
# FIREBASE_SERVICE_ACCOUNT_KEY=path/to/serviceAccountKey.json
# Optional: TOKEN_COST_LIMIT (default 1.0), INPUT_COST_PER_TOKEN (default 0.00000015), OUTPUT_COST_PER_TOKEN (default 0.0000006).